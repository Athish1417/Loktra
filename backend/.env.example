# Copy to .env and adjust. Every value has a safe default — .env is optional for local dev.

PROJECT_NAME=Loktra
DATABASE_URL=sqlite:///./loktra.db

# CHANGE THIS in production
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI provider: auto | gemini | fallback
#   auto     -> use Gemini if GEMINI_API_KEY is set, else rule-based fallback
#   gemini   -> force Gemini (falls back at runtime if a call fails)
#   fallback -> force rule-based (no external calls, no key needed)
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

UPLOAD_DIR=uploads
